# Copy this file to .env.local in the repository root for local RunPod launches.
# Do not commit the populated .env.local file.

# Shared API keys already present in the service repo env in some environments.
RUNPOD_API_KEY=
HF_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Required for training launches.
HF_USERNAME=
GITHUB_TOKEN=
GITHUB_REPO=unoa-eng/dalbitalba-train-data

# Required only for local eval launches.
HF_ADAPTER_REPO=

# Optional notifications and defaults.
NTFY_TOPIC=
BASE_MODEL=upstage/SOLAR-10.7B-v1.0
GPU_TYPE=NVIDIA A100 80GB PCIe
CONTAINER_IMAGE=runpod/pytorch:2.2.0-py3.10-cuda12.1.1-devel-ubuntu22.04
