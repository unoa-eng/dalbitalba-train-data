# Copy this file to .env.local in the repository root for local RunPod launches.
# Do not commit the populated .env.local file.

# Shared API keys already present in the service repo env in some environments.
RUNPOD_API_KEY=
HF_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# W&B 학습 모니터링 필수 (paper-grade 실험에는 반드시 설정)
WANDB_API_KEY=
# 아래 항목은 optional — 설정하지 않으면 script 기본값(dalbitalba-round2 등)이 사용됨
WANDB_PROJECT=
WANDB_TAGS=
WANDB_NOTES=

# Required for training launches.
HF_USERNAME=
GITHUB_TOKEN=
GITHUB_REPO=unoa-eng/dalbitalba-train-data

# Required only for local eval launches.
HF_ADAPTER_REPO=

# Optional notifications and defaults.
NTFY_TOPIC=

# Hardened defaults aligned with codex/budget30-macmini-loop invariants.
# DO NOT regress to SOLAR or CUDA 12.1 — they break the budget30 cost model
# and the run_train.sh / chain_train.sh preflight assumptions.
BASE_MODEL=Qwen/Qwen3-8B-Base
# Qwen3-8B-Base HF revision; commit SHA or 'main'; pin for reproducibility
BASE_MODEL_REVISION=
GPU_TYPE=NVIDIA L40S
CONTAINER_IMAGE=runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04
BUDGET_PROFILE=budget30
