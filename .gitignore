logs/
out/
.state/
.env.local
__pycache__/
*.pyc
*.log

eval/results/
eval/*.html
eval/*.md

# Top-level transient workspace copies stay ignored.
ai_generated.jsonl
eval_samples.jsonl
eval_key.json

# But the run_dir copies under runs/eval-run-*/ MUST be committed so
# offline native-speaker review has access to the actual generated texts
# (pod volumes are lost on EXIT, and judge JSONs don't carry text).
!runs/**/ai_generated.jsonl
!runs/**/eval_samples.jsonl
!runs/**/eval_key.json
# Training run logs — persist_run_artifacts copies chain/CPT/SFT/merge
# logs into runs/train-run-*/ for post-mortem. Without these negations
# the *.log ignore above makes the commits empty.
!runs/**/*.log
!runs/**/preflight.log

# Local verifier outputs are reproducible and should not be pushed as run artifacts.
runs/local-verification-*/
runs/latest-local-verification.json

# Pre-clean backups — large binary snapshots, local-only.
archive/dataset-backups/
.omc/
.venv
.venv*/
**/__pycache__/
.hf-home/
hf_cache/
.cache/huggingface/
source_db_cache/
runs/**/adapter/
runs/**/adapter_model.safetensors
runs/**/adapter_config.json
