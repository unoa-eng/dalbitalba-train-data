# First paid GPU run after local verification.
# Goal: prove CPT -> merge -> SFT -> HF checkpoint -> eval artifact plumbing,
# not model quality.

CPT_LIMIT_ROWS=512
CPT_VAL_LIMIT_ROWS=128
SFT_RAW_LIMIT_ROWS=512
SFT_PAIR_LIMIT_ROWS=128
SFT_VAL_LIMIT_ROWS=128

CPT_MAX_STEPS=20
SFT_MAX_STEPS=20
CPT_SAVE_STEPS=10
SFT_SAVE_STEPS=10
CPT_EVAL_STEPS=10
SFT_EVAL_STEPS=10
CPT_LOGGING_STEPS=5
SFT_LOGGING_STEPS=5

EVAL_MODE=phase6
EVAL_MAX_ROWS=50
RUN_MAUVE=0

BASE_MODEL="Qwen/Qwen3-8B-Base"
GPU_TYPE="NVIDIA L40S,NVIDIA A100 80GB PCIe,NVIDIA RTX 6000 Ada Generation"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
