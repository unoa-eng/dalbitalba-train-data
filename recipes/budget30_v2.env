# Budget30 v2: Structured CPT with debate-round-1 fixes applied.
# LR=1e-4 restored for 8B LoRA / fresh-token adaptation; keep 5e-5 as a later sweep anchor.

BASE_MODEL="Qwen/Qwen3-8B-Base"
GPU_TYPE="NVIDIA L40S"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
BUDGET_PROFILE=budget30
TRAIN_CPT_JSONL=v3-data/cpt_structured_v3.jsonl
CPT_TOKENIZER_DIR=v3-data/tokenizer
CPT_EXTEND_TOKENS=1
CPT_LORA_EMBED=1
CPT_USE_PACKING=1
REPLAY_JSONL=v3-data/replay_korean_5k.jsonl

CPT_LR=1e-4
CPT_NUM_EPOCHS=1
CPT_EMBED_WARMUP_STEPS=20
SFT_NUM_EPOCHS=0
SKIP_SFT=1

CPT_SAVE_STEPS=250
CPT_EVAL_STEPS=500
CPT_LOGGING_STEPS=25

CPT_TIMEOUT_HOURS=32
MERGE_TIMEOUT_HOURS=2
SFT_TIMEOUT_HOURS=1
HF_UPLOAD_TIMEOUT_HOURS=1

EVAL_MODE=phase6
RUN_MAUVE=0
