# Budget30 v2 + Obsidian auxiliary metadata experiment
#
# This is an opt-in experiment path. The training prompt format stays unchanged.
# The SFT stage builds a runtime variant that mildly oversamples rows whose
# source_id appears in the curated Obsidian sample vault.

BASE_MODEL="Qwen/Qwen3-8B-Base"
GPU_TYPE="NVIDIA L40S"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
BUDGET_PROFILE=budget30
TRAIN_CPT_JSONL=v3-data/cpt_structured_v3.jsonl
CPT_TOKENIZER_DIR=v3-data/tokenizer
CPT_EXTEND_TOKENS=1
CPT_LORA_EMBED=1
CPT_USE_PACKING=1
REPLAY_JSONL=v3-data/replay_korean_5k.jsonl

CPT_LR=1e-4
CPT_NUM_EPOCHS=1
CPT_EMBED_WARMUP_STEPS=20
SFT_NUM_EPOCHS=1
SFT_INPUT_JSONL=v3-data/sft_5task_v3.jsonl
SFT_LR=5e-5
SFT_OBSIDIAN_ENABLE=1
SFT_OBSIDIAN_TARGET_RATIO=0.08

CPT_SAVE_STEPS=250
CPT_EVAL_STEPS=500
CPT_LOGGING_STEPS=25

CPT_TIMEOUT_HOURS=32
MERGE_TIMEOUT_HOURS=2
SFT_TIMEOUT_HOURS=4
HF_UPLOAD_TIMEOUT_HOURS=1

EVAL_MODE=phase6
RUN_MAUVE=0
