# Legacy cost-constrained CPT-only probe.
# Goal: finish CPT and preserve auditable artifacts. This is not the final
# paper8b/full-quality run because it intentionally skips SFT.

BASE_MODEL="Qwen/Qwen3-8B-Base"
# Pinned to known-good Qwen3-8B-Base HF HEAD (verified 2026-05-12 by Codex).
# Do NOT change to "main" — prelaunch_research_check.py FAILS on paper8b/budget30
# with floating refs.
BASE_MODEL_REVISION="49e3418fbbbca6ecbdf9608b4d22e5a407081db4"
# L40S only — A100 ($1.19/hr) × 32h CPT = $38.08 alone, blows the $30 ceiling.
# If L40S is unavailable, fail closed and retry later instead of fallback.
GPU_TYPE="NVIDIA L40S"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
BUDGET_PROFILE=budget30
BUDGET_CAP_USD=60

CPT_NUM_EPOCHS=1
SFT_NUM_EPOCHS=0
SKIP_SFT=1
# This probe uses the enriched CPT corpus for both CPT passes. The full
# paper8b recipe still uses cpt_corpus.v3.jsonl in phase 2 to preserve short
# community-style utterances.
CPT_PHASE_1_DATA=cpt_enriched.jsonl
CPT_PHASE_2_DATA=cpt_enriched.jsonl

CPT_SAVE_STEPS=250
CPT_EVAL_STEPS=500
CPT_LOGGING_STEPS=25

CPT_TIMEOUT_HOURS=32
MERGE_TIMEOUT_HOURS=2
SFT_TIMEOUT_HOURS=1
HF_UPLOAD_TIMEOUT_HOURS=1

# CPT cold-start protection (B5c — review 2026-05-12)
# paper8b uses 1e-4 / 0.08; budget30 inherits the same to avoid 2e-4 / 0.03 spike.
CPT_LR=1e-4
CPT_WARMUP_RATIO=0.08

EVAL_MODE=phase6
RUN_MAUVE=0

# W&B tracking (optional for CPT-only probe, but set defaults to silence prelaunch WARN)
WANDB_PROJECT=dalbitalba-budget30-probe
WANDB_RUN_GROUP=budget30-probe
WANDB_TAGS=cpt-only,budget30,probe
