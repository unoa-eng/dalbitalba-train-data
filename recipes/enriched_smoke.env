# Enriched Smoke: minimal CPT+SFT to verify pipeline with enriched data
# 목적: 파이프라인 검증 only, 품질 판단 불가

BASE_MODEL="Qwen/Qwen3-8B-Base"
GPU_TYPE="NVIDIA L40S,NVIDIA A100 80GB PCIe"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"

TRAIN_CPT_JSONL=cpt_enriched.jsonl
TRAIN_SFT_PAIR_JSONL=sft_pairs_enriched_compat.jsonl
SFT_RAW_JSONL=cpt_enriched.jsonl

SKIP_SFT=0

CPT_LIMIT_ROWS=512
CPT_VAL_LIMIT_ROWS=128
SFT_RAW_LIMIT_ROWS=512
SFT_PAIR_LIMIT_ROWS=256
SFT_VAL_LIMIT_ROWS=128

CPT_MAX_STEPS=20
SFT_MAX_STEPS=20
CPT_SAVE_STEPS=10
SFT_SAVE_STEPS=10
CPT_EVAL_STEPS=10
SFT_EVAL_STEPS=10

EVAL_MODE=phase6
EVAL_MAX_ROWS=30
RUN_MAUVE=0

CPT_TIMEOUT_HOURS=2
MERGE_TIMEOUT_HOURS=2
SFT_TIMEOUT_HOURS=2
HF_UPLOAD_TIMEOUT_HOURS=1
