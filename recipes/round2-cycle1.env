# Round-2 cycle-1 recipe (paper-grade profile)
# Authored: 2026-04-28 by round2 windows-NPU session
# Consumed by: chain_train.sh / launch_train_pod.py
#
# Pre-flight requirement: scripts/round2_build_tc_sft.py and
# scripts/round2_build_orpo_pairs.py must have been run in the WSL clone
# (cycle-0 prep step) to produce sft_thread_conditioned.jsonl and orpo_pairs.jsonl.

# --- model ---
BASE_MODEL=Qwen/Qwen3-8B-Base

# --- CPT (Phase-1 broad + Phase-2 clean) ---
CPT_PHASE_1_DATA=cpt_enriched.jsonl
CPT_PHASE_2_DATA=cpt_corpus.v3.jsonl
CPT_NUM_EPOCHS=1
LORA_R=128
CPT_USE_DORA=1
SEQ_LEN=2048
OVERSAMPLE_LG_XXL=2
# Phase 5.8 mitigation for cold-start val-loss spike (5.642 -> 7.169 nat across
# iter 1->100 in local H stage). lr=2e-4 was too aggressive for the very small
# effective batch on cold model; warmup ratio bumped from 3% -> ~8% to
# stabilize early adapter alignment. train_cpt.py wires both via
# transformers TrainingArguments (lr_scheduler_type="cosine" + warmup_steps).
CPT_LR=1e-4
CPT_WARMUP_RATIO=0.08

# --- SFT (Phase-3 thread-conditioned + persona prefix + loss weight) ---
SFT_DATA=sft_thread_conditioned.jsonl
SFT_EVAL_DATA=sft_thread_conditioned.eval.jsonl
SFT_NUM_EPOCHS=2
SFT_RAW_RATIO=0.0
SFT_PERSONA_LIST=runs/round2-obsidian-synthesis/persona-30-extracted.json
SFT_LOSS_WEIGHT_ARGOT=1.5
SFT_LOSS_WEIGHT_THRESHOLD=2

# --- ORPO (Phase-4 preference) ---
ORPO_DATA=orpo_pairs.jsonl
ORPO_NUM_EPOCHS=0
ORPO_BETA=0.1
ORPO_STATUS=deferred_until_real_judged_pairs

# --- Generation ---
GENERATION_TEMP=0.6
GENERATION_TOP_P=0.9
GENERATION_MAX_NEW_TOKENS=400

# --- Eval gate ---
EVAL_GATE=phase6_eval_v2
EVAL_GATE_REQUIRES_PASS=base+v2
EVAL_PERSONA_LIST=runs/round2-obsidian-synthesis/persona-30-extracted.json
EVAL_INPUT_DATA=sft_thread_conditioned.eval.jsonl
EVAL_SECONDARY_AI_OPTIONAL=1   # cross_machine_agreement waived if not provided

# --- Mutator (round2 R7-R11 added on top of R1-R6) ---
MUTATOR_RULESET=round2-r1-r11

# --- Monitoring / traceability ---
WANDB_PROJECT=dalbitalba-round2
WANDB_RUN_GROUP=round2-qwen3-8b-paper
WANDB_TAGS=round2,qwen3-8b,cpt,dora,tc-sft,orpo,phase6-v2

# --- Budget ---
BUDGET_PROFILE=paper8b
EXPECTED_USD_MIN=30
EXPECTED_USD_MAX=80
BUDGET_CAP_USD=120

# --- Stop conditions ---
STOP_FILE=.state/round2/STOP
STAGNATION_DELTA=0.01
CONVERGENCE_BIGRAM_JSD=0.04
