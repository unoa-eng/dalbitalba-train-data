# Enriched Full: CPT + SFT with enriched datasets
# 목표: 문체 흡수(CPT) + 댓글/제목/reply 생성 능력(SFT)

BASE_MODEL="Qwen/Qwen3-8B-Base"
GPU_TYPE="NVIDIA L40S"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
BUDGET_PROFILE=enriched_full

TRAIN_CPT_JSONL=cpt_enriched.jsonl
TRAIN_SFT_PAIR_JSONL=sft_pairs_enriched_compat.jsonl
SFT_RAW_JSONL=cpt_enriched.jsonl

SKIP_SFT=0
CPT_NUM_EPOCHS=1
SFT_NUM_EPOCHS=2
SFT_RAW_RATIO=0.5

CPT_LR=1e-4
SFT_LR=5e-5

CPT_SAVE_STEPS=250
CPT_EVAL_STEPS=500
CPT_LOGGING_STEPS=25
SFT_SAVE_STEPS=200
SFT_EVAL_STEPS=400
SFT_LOGGING_STEPS=25

CPT_TIMEOUT_HOURS=20
MERGE_TIMEOUT_HOURS=2
SFT_TIMEOUT_HOURS=20
HF_UPLOAD_TIMEOUT_HOURS=1

EVAL_MODE=phase6
RUN_MAUVE=0
