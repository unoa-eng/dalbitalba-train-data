# Enriched CPT-only: context-aware training with metadata
# 데이터: 프로모 정리 + 문맥파괴 제거 + val 분리 + 조회수 리스케일 완료

BASE_MODEL="Qwen/Qwen3-8B-Base"
GPU_TYPE="NVIDIA L40S"
CONTAINER_IMAGE="runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04"
BUDGET_PROFILE=enriched_cpt

TRAIN_CPT_JSONL=cpt_enriched.jsonl
SKIP_SFT=1
SFT_NUM_EPOCHS=0

CPT_LR=1e-4
CPT_NUM_EPOCHS=1
CPT_SAVE_STEPS=250
CPT_EVAL_STEPS=500
CPT_LOGGING_STEPS=25

CPT_TIMEOUT_HOURS=32
MERGE_TIMEOUT_HOURS=2
SFT_TIMEOUT_HOURS=1
HF_UPLOAD_TIMEOUT_HOURS=1

EVAL_MODE=phase6
RUN_MAUVE=0
